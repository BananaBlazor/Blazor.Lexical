@namespace Blazor.Lexical

@* Drag-to-reorder grip — an ITEM inside a <LexicalBlockGutter>, not a rail of its own:

     <LexicalBlockGutter Position="LexicalGutterPosition.LeftInside">
         <LexicalAddBlockButton />
         <LexicalDragHandle />
     </LexicalBlockGutter>

   The gutter owns the hover tracking and the positioning; this contributes only the grip
   markup (marker: data-lexical-drag-grip, draggable). JS delegates the drag from the
   editor root, so the grip works in whichever rail it is placed. Reordering happens
   through Lexical node moves, so history and serialization stay correct. No interop. *@
<span class="blazor-lexical__gutter-item blazor-lexical__drag-grip @CssClass"
      data-lexical-drag-grip
      draggable="true"
      title="@Title"
      aria-label="@Title">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <span>⠿</span>
    }
</span>

@code {
    /// <summary>Custom content for the grip (defaults to a braille-dots glyph).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Tooltip / accessible label for the grip.</summary>
    [Parameter] public string Title { get; set; } = "Drag to move";

    /// <summary>Extra CSS class(es) applied to the grip.</summary>
    [Parameter] public string? CssClass { get; set; }
}
