@page "/"
@page "/interop-harness"

@* Deterministic harness that exercises every Blazor <-> Lexical JS touchpoint.
   Driven by the Tests.Integration Playwright suite. Stable ids only. *@

<PageTitle>Interop Harness</PageTitle>

<h1>Blazor.Lexical interop harness</h1>

<section>
    <h2>Main editor (placeholder, css class, theme, change callback, get/set)</h2>
    <LexicalEditor @ref="_main"
                   Id="editor-main"
                   Placeholder="Type here…"
                   CssClass="harness-main"
                   Theme="@(new { paragraph = "harness-paragraph" })"
                   OnContentChanged="OnMainChanged" />

    <div>
        <button id="btn-get" @onclick="GetMain">Get text</button>
        <button id="btn-set" @onclick="SetMain">Set text</button>
    </div>
    <p>Get result: <span id="get-result">@_getResult</span></p>
    <p>Change callback: <span id="change-log">@_changeLog</span></p>
    <p>Change count: <span id="change-count">@_changeCount</span></p>
</section>

<section>
    <h2>Formats (HTML / Markdown / editor-state JSON)</h2>

    <div>
        <button id="btn-get-html" @onclick="GetHtml">Get HTML</button>
        <button id="btn-set-html" @onclick="SetHtml">Set HTML</button>
    </div>
    <p>HTML result: <span id="html-result">@_htmlResult</span></p>

    <div>
        <button id="btn-get-markdown" @onclick="GetMarkdown">Get Markdown</button>
        <button id="btn-set-markdown" @onclick="SetMarkdown">Set Markdown</button>
    </div>
    <p>Markdown result: <span id="markdown-result">@_markdownResult</span></p>

    <div>
        <button id="btn-get-json" @onclick="GetJson">Get JSON</button>
        <button id="btn-set-json" @onclick="SetJson">Set JSON (restore captured)</button>
    </div>
    <p>JSON result: <span id="json-result">@_jsonResult</span></p>
</section>

<section>
    <h2>Lists (insertUnorderedList / insertOrderedList / removeList)</h2>
    <LexicalEditor @ref="_lists" Id="editor-lists" />
    <div>
        <button id="btn-ul" @onclick="InsertUnordered">Bulleted</button>
        <button id="btn-ol" @onclick="InsertOrdered">Numbered</button>
        <button id="btn-list-remove" @onclick="RemoveListFmt">Remove list</button>
        <button id="btn-list-md" @onclick="SetListMarkdown">Set list markdown</button>
        <button id="btn-list-get-md" @onclick="GetListMarkdown">Get list markdown</button>
    </div>
    <p>List markdown result: <span id="list-md-result">@_listMarkdownResult</span></p>
</section>

<section>
    <h2>Links (toggleLink set / remove)</h2>
    <LexicalEditor @ref="_links" Id="editor-links" />
    <div>
        <button id="btn-link-set" @onclick="SetLink">Set link</button>
        <button id="btn-link-remove" @onclick="RemoveLink">Remove link</button>
        <button id="btn-link-md" @onclick="SetLinkMarkdown">Set link markdown</button>
        <button id="btn-link-get-md" @onclick="GetLinkMarkdown">Get link markdown</button>
    </div>
    <p>Link markdown result: <span id="link-md-result">@_linkMarkdownResult</span></p>
</section>

<section>
    <h2>Formatting — nested toolbar, NO callbacks (pure JS, zero interop)</h2>
    @* No OnContentChanged/OnSelectionChanged: proves built-in toolbar buttons format
       entirely in JS and drive data-lexical-active without any .NET round-trip. *@
    <LexicalEditor @ref="_format"
                   Id="editor-format"
                   CssClass="harness-format"
                   Placeholder="Type here…"
                   Theme="LexicalTheme.Default">
        <LexicalToolbar />
    </LexicalEditor>

    @* Direct C# method calls (the opt-in programmatic path), driving the same editor. *@
    <div>
        <button id="btn-fmt-bold" @onclick="() => FormatFmt(LexicalTextFormat.Bold)">Bold</button>
        <button id="btn-block-h1" @onclick="() => BlockFmt(LexicalBlockType.Heading1)">H1</button>
        <button id="btn-block-quote" @onclick="() => BlockFmt(LexicalBlockType.Quote)">Quote</button>
        <button id="btn-block-p" @onclick="() => BlockFmt(LexicalBlockType.Paragraph)">Paragraph</button>
        <button id="btn-fmt-undo" @onclick="UndoFmt">Undo</button>
        <button id="btn-fmt-redo" @onclick="RedoFmt">Redo</button>
        <button id="btn-fmt-get-html" @onclick="GetFmtHtml">Get HTML</button>
    </div>
    <p>Format HTML result: <span id="fmt-html-result">@_fmtHtmlResult</span></p>
</section>

<section>
    <h2>Formatting — opt-in callbacks (selection + content push)</h2>
    <LexicalEditor @ref="_notify"
                   Id="editor-notify"
                   CssClass="harness-notify"
                   OnContentChanged="OnNotifyContent"
                   OnSelectionChanged="OnNotifySelection">
        <LexicalToolbar ShowLink="false" />
    </LexicalEditor>
    <p>Notify change: <span id="notify-change">@_notifyChange</span></p>
    <p>Notify change count: <span id="notify-change-count">@_notifyChangeCount</span></p>
    <p>Notify sel bold: <span id="notify-sel-bold">@_notifySelBold</span></p>
    <p>Notify sel block: <span id="notify-sel-block">@_notifySelBlock</span></p>
    <p>Notify sel count: <span id="notify-sel-count">@_notifySelCount</span></p>
</section>

<section>
    <h2>Overlays — floating toolbar, slash menu, drag handle (pure JS, zero interop)</h2>
    @* No callbacks wired: proves the in-editor overlays are entirely client-side.
       The overlays activate purely from the marker markup they render. *@
    <LexicalEditor Id="editor-overlays"
                   CssClass="harness-overlays"
                   Placeholder="Type '/' for blocks, select text for the toolbar…"
                   Theme="LexicalTheme.Default">
        <LexicalFloatingToolbar />
        <LexicalSlashMenu />
        @* The playground-style left rail, composed from its two items. *@
        <LexicalBlockGutter Position="LexicalGutterPosition.LeftInside">
            <LexicalAddBlockButton />
            <LexicalDragHandle />
        </LexicalBlockGutter>
    </LexicalEditor>
</section>

<section>
    <h2>Link editor popup — toolbar link button + floating editor (pure JS, zero interop)</h2>
    @* No callbacks wired: the toolbar link button inserts a placeholder link and the
       floating <LexicalLinkEditor/> opens to edit its URL — all client-side. *@
    <LexicalEditor Id="editor-linkeditor"
                   CssClass="harness-linkeditor"
                   Placeholder="Select text, then click the link button…"
                   Theme="LexicalTheme.Default">
        <LexicalToolbar />
        <LexicalLinkEditor />
    </LexicalEditor>
</section>

<section>
    <h2>Tables — insert picker, slash /table, in-cell action menu (pure JS, zero interop)</h2>
    @* No callbacks wired: proves table insert + in-cell editing are entirely
       client-side. The picker, slash item, and action menu drive the @lexical/table
       plugin without any .NET round-trip. *@
    <LexicalEditor @ref="_tables"
                   Id="editor-tables"
                   CssClass="harness-tables"
                   Placeholder="Insert a table via the toolbar or /table…"
                   Theme="LexicalTheme.Default">
        <LexicalToolbar />
        <LexicalSlashMenu />
        @* Declared *after* the toolbar and slash menu on purpose: it proves the
           ExtensionsChanged re-render, i.e. that chrome declared above <LexicalTables/>
           still picks the feature up. *@
        <LexicalTables />
        <LexicalTableEditor />
    </LexicalEditor>

    @* Direct C# insert (the opt-in programmatic path), driving the same editor. *@
    <div>
        <button id="btn-insert-table" @onclick="InsertTableFmt">Insert 2×3 table</button>
        <button id="btn-tables-get-html" @onclick="GetTablesHtml">Get HTML</button>
    </div>
    <p>Tables HTML result: <span id="tables-html-result">@_tablesHtmlResult</span></p>
</section>

<section>
    <h2>Mentions — @@ typeahead (provider + OnSelected) and # freeform highlight</h2>
    @* The @@ editor wires a fake provider and OnSelected (opt-in interop) plus a
       content callback so the silent-refresh test can prove refresh does not notify.
       The # editor is freeform-only (no provider): pure-JS hashtag highlighting. *@
    <LexicalEditor @ref="_mentionPeople"
                   Id="editor-mention-people"
                   CssClass="harness-mention-people"
                   Placeholder="Type a mention…"
                   OnContentChanged="OnMentionContent"
                   Theme="LexicalTheme.Default">
        <LexicalMention Initiator="@AtInitiator"
                        Color="#1877e8"
                        Provider="ResolvePeople"
                        OnSelected="OnMentionSelected" />
    </LexicalEditor>

    <div>
        <button id="btn-mention-list" @onclick="GetMentionList">List mentions</button>
        <button id="btn-mention-refresh" @onclick="RefreshMentionName">Rename first mention</button>
    </div>
    <p>Mention selected: <span id="mention-selected">@_mentionSelected</span></p>
    <p>Mention list: <span id="mention-list">@_mentionList</span></p>
    <p>Mention refresh count: <span id="mention-refresh-count">@_mentionRefreshCount</span></p>
    <p>Mention content-change count: <span id="mention-change-count">@_mentionChangeCount</span></p>

    <LexicalEditor Id="editor-mention-hashtag"
                   CssClass="harness-mention-hashtag"
                   Placeholder="Type #tags…"
                   Theme="LexicalTheme.Default">
        <LexicalMention Initiator="#" Color="#e8b800" Freeform="true" />
    </LexicalEditor>
</section>

<section>
    <h2>Extensions — the badge reference extension (external ESM, opt-in interop)</h2>
    @* Two editors prove the extension SDK's invariants as a pair, like
       .harness-format / .harness-notify do for the core:

         * editor-badge-notify wires OnBadgeClicked, so HasInvokeHandler is true and
           clicking a badge round-trips to C#.
         * editor-badge-quiet wires nothing: the same extension, the same custom node
           and the same client-side insert, but zero JS→.NET calls. *@
    <LexicalEditor @ref="_badgeNotify"
                   Id="editor-badge-notify"
                   CssClass="harness-badge-notify"
                   Placeholder="Insert a badge…"
                   Theme="LexicalTheme.Default">
        <BadgeExtension @ref="_badgeNotifyExt" Label="Draft" OnBadgeClicked="OnBadgeClicked" />
    </LexicalEditor>

    <div>
        <button id="btn-badge-insert-cs" @onclick="InsertBadgeFromCs">Insert badge from C#</button>
        <button id="btn-badge-count" @onclick="CountBadges">Count badges</button>
        <button id="btn-badge-html" @onclick="GetBadgeHtml">Get HTML</button>
    </div>
    <p>Badge clicked: <span id="badge-clicked">@_badgeClicked</span></p>
    <p>Badge click count: <span id="badge-click-count">@_badgeClickCount</span></p>
    <p>Badge count: <span id="badge-count">@_badgeCount</span></p>
    <p>Badge HTML: <span id="badge-html-result">@_badgeHtmlResult</span></p>

    <LexicalEditor Id="editor-badge-quiet"
                   CssClass="harness-badge-quiet"
                   Placeholder="Insert a badge (no callbacks)…"
                   Theme="LexicalTheme.Default">
        <BadgeExtension Label="Quiet" />
    </LexicalEditor>
</section>

<section>
    <h2>TOC — heading outline, rendered by JS and pushed to .NET</h2>
    @* Paired like .harness-format / .harness-notify:

         * editor-toc-notify wires OnTocChanged AND a render target, so both surfaces
           run: JS builds #toc-target-notify and the model reaches C#.
         * editor-toc-quiet renders into #toc-target-quiet with no callback at all —
           the anchors and the list still appear, with zero JS→.NET calls. *@
    <LexicalEditor @ref="_tocNotify"
                   Id="editor-toc-notify"
                   CssClass="harness-toc-notify"
                   Theme="LexicalTheme.Default">
        <LexicalToc @ref="_tocNotifyExt"
                    TargetSelector="#toc-target-notify"
                    MaxLevel="3"
                    AnchorPrefix="n-"
                    OnTocChanged="OnTocChanged" />
    </LexicalEditor>
    <nav id="toc-target-notify"></nav>
    <p>TOC count: <span id="toc-count">@_tocCount</span></p>
    <p>TOC push count: <span id="toc-push-count">@_tocPushCount</span></p>
    <p>TOC flat: <span id="toc-flat">@_tocFlat</span></p>

    @* The same model, rendered by Blazor instead of by JS. *@
    <LexicalTocList Entries="_tocEntries" CssClass="harness-toc-list" />

    <div>
        <button id="btn-toc-get" @onclick="GetToc">Get TOC</button>
        <button id="btn-toc-scroll" @onclick="ScrollToFirstAnchor">Scroll to first</button>
    </div>
    <p>TOC get result: <span id="toc-get-result">@_tocGetResult</span></p>
    <p>TOC scroll result: <span id="toc-scroll-result">@_tocScrollResult</span></p>

    <LexicalEditor Id="editor-toc-quiet"
                   CssClass="harness-toc-quiet"
                   Theme="LexicalTheme.Default">
        <LexicalToc TargetSelector="#toc-target-quiet" AnchorPrefix="q-" />
    </LexicalEditor>
    <nav id="toc-target-quiet"></nav>
</section>

<section>
    <h2>Marks — app-owned ids over spans of text</h2>
    @* editor-marks-notify wires both callbacks (opt-in interop); editor-marks-quiet
       wires neither, so wrapping and removing still work from C# while JS never calls
       back. Mark ids are minted here, by the app — the library never generates one. *@
    <LexicalEditor @ref="_marksNotify"
                   Id="editor-marks-notify"
                   CssClass="harness-marks-notify"
                   Theme="LexicalTheme.Default"
                   OnContentChanged="OnMarksContent">
        <LexicalMarks @ref="_marksNotifyExt"
                      OnMarkClicked="OnMarkClicked"
                      OnActiveMarksChanged="OnActiveMarksChanged" />
    </LexicalEditor>

    <div>
        <button id="btn-mark-wrap-a" @onclick="@(() => WrapMark("mark-a"))">Mark A</button>
        <button id="btn-mark-wrap-b" @onclick="@(() => WrapMark("mark-b"))">Mark B</button>
        <button id="btn-mark-ids" @onclick="ListMarkIds">List ids</button>
        <button id="btn-mark-ids-sel" @onclick="ListMarkIdsAtSelection">Ids at selection</button>
        <button id="btn-mark-remove-a" @onclick="@(() => RemoveMark("mark-a", false))">Remove A</button>
        <button id="btn-mark-remove-a-silent" @onclick="@(() => RemoveMark("mark-a", true))">Remove A (silent)</button>
        <button id="btn-mark-active" @onclick="@(() => SetActiveMark("mark-a"))">Activate A</button>
    </div>
    <p>Mark clicked: <span id="mark-clicked">@_markClicked</span></p>
    <p>Mark active push: <span id="mark-active">@_markActive</span></p>
    <p>Mark ids: <span id="mark-ids">@_markIds</span></p>
    <p>Mark ids at selection: <span id="mark-ids-selection">@_markIdsAtSelection</span></p>
    <p>Mark wrap result: <span id="mark-wrap-result">@_markWrapResult</span></p>
    <p>Mark remove count: <span id="mark-remove-count">@_markRemoveCount</span></p>
    <p>Marks content-change count: <span id="marks-change-count">@_marksChangeCount</span></p>

    <LexicalEditor @ref="_marksQuiet"
                   Id="editor-marks-quiet"
                   CssClass="harness-marks-quiet"
                   Theme="LexicalTheme.Default">
        <LexicalMarks @ref="_marksQuietExt" />
    </LexicalEditor>
    <div>
        <button id="btn-mark-quiet-wrap" @onclick="WrapQuietMark">Mark (quiet)</button>
    </div>
</section>

<section>
    <h2>Stats — word/character counts written to the page and pushed to .NET</h2>
    <LexicalEditor @ref="_statsNotify"
                   Id="editor-stats-notify"
                   CssClass="harness-stats-notify"
                   Theme="LexicalTheme.Default">
        <LexicalStats @ref="_statsNotifyExt"
                      TargetSelector="#stats-target-notify"
                      Template="{words}w/{characters}c"
                      OnStatsChanged="OnStatsChanged" />
    </LexicalEditor>
    <p>Stats target: <span id="stats-target-notify"></span></p>
    <p>Stats push: <span id="stats-push">@_statsPush</span></p>
    <div>
        <button id="btn-stats-get" @onclick="GetStats">Get stats</button>
    </div>
    <p>Stats get result: <span id="stats-get-result">@_statsGetResult</span></p>

    <LexicalEditor Id="editor-stats-quiet"
                   CssClass="harness-stats-quiet"
                   Theme="LexicalTheme.Default">
        <LexicalStats TargetSelector="#stats-target-quiet" Template="{words} words" />
    </LexicalEditor>
    <p>Stats quiet target: <span id="stats-target-quiet"></span></p>
</section>

<section>
    <h2>Horizontal rule — an opt-in node, inserted by command token or from C#</h2>
    @* editor-hr carries the extension; editor-hr-absent deliberately does NOT, which is
       what proves the hr:insert token is an inert no-op rather than an error when the
       node was never registered. *@
    @* The token buttons live INSIDE the editor: the delegated dispatcher is bound to the
       editor root, so a data-lexical-command button outside it would never fire. *@
    <LexicalEditor @ref="_hrEditor"
                   Id="editor-hr"
                   CssClass="harness-hr"
                   Theme="LexicalTheme.Default">
        <button id="btn-hr-insert" type="button" data-lexical-command="hr:insert">Rule</button>
        <LexicalHorizontalRule @ref="_hrExt" />
    </LexicalEditor>
    <div>
        <button id="btn-hr-insert-cs" @onclick="InsertRuleFromCSharp">Rule (C#)</button>
        <button id="btn-hr-get-html" @onclick="GetHrHtml">Get HTML</button>
        <button id="btn-hr-set-html" @onclick="SetHrHtml">Set HTML</button>
    </div>
    <p>HR html: <span id="hr-html">@_hrHtml</span></p>

    <LexicalEditor Id="editor-hr-absent"
                   CssClass="harness-hr-absent"
                   Theme="LexicalTheme.Default">
        <button id="btn-hr-absent-insert" type="button" data-lexical-command="hr:insert">Rule</button>
    </LexicalEditor>
</section>

<section>
    <h2>Tab indent — opt-in Tab/Shift+Tab block indentation</h2>
    @* editor-tab-indent binds Tab; editor-tab-plain does not, which is the invariant that
       matters: an editor that did not ask for it must leave Tab to the browser. *@
    <LexicalEditor @ref="_tabIndent"
                   Id="editor-tab-indent"
                   CssClass="harness-tab-indent"
                   Theme="LexicalTheme.Default">
        <LexicalTabIndent />
    </LexicalEditor>

    <LexicalEditor @ref="_tabCapped"
                   Id="editor-tab-capped"
                   CssClass="harness-tab-capped"
                   Theme="LexicalTheme.Default">
        <LexicalTabIndent MaxIndent="2" />
    </LexicalEditor>

    <LexicalEditor @ref="_tabPlain"
                   Id="editor-tab-plain"
                   CssClass="harness-tab-plain"
                   Theme="LexicalTheme.Default" />
    @* The indent level is read from the editor state rather than a CSS side effect:
       "the block's indent is 1" is the actual claim, and it does not move with styling. *@
    <div>
        <button id="btn-tab-indent-of" @onclick="ReadTabIndent">Indent (bound)</button>
        <button id="btn-tab-capped-of" @onclick="ReadCappedIndent">Indent (capped)</button>
        <button id="btn-tab-plain-of" @onclick="ReadPlainIndent">Indent (plain)</button>
    </div>
    <p>Tab indent: <span id="tab-indent">@_tabIndentLevel</span></p>
</section>

<section>
    <h2>Extension hardening — colliding modules are skipped, the editor survives</h2>
    @* Three editors, each loading a pair of consumer extension modules that collide in a
       different way. In every case the SECOND module must be skipped with a console error
       while the editor stays alive and typeable — the whole point of failing soft. *@
    <LexicalEditor Id="editor-collide-name"
                   CssClass="harness-collide-name"
                   Theme="LexicalTheme.Default">
        <HarnessCollider Variant="name-a" />
        <HarnessCollider Variant="name-b" />
    </LexicalEditor>

    <LexicalEditor Id="editor-collide-nodetype"
                   CssClass="harness-collide-nodetype"
                   Theme="LexicalTheme.Default">
        <HarnessCollider Variant="node-a" />
        <HarnessCollider Variant="node-b" />
    </LexicalEditor>

    <LexicalEditor Id="editor-collide-declared"
                   CssClass="harness-collide-declared"
                   Theme="LexicalTheme.Default">
        <HarnessCollider Variant="conflict-a" />
        <HarnessCollider Variant="conflict-b" />
    </LexicalEditor>
</section>

<section>
    <h2>Block gutter — composable per-block rails</h2>
    @* editor-gutter-notify carries TWO rails, proving they coexist: a left rail with the
       two built-in JS-driven items, and a right rail with host actions. OnBlockHovered is
       wired on the right one only, so the fan-out and the per-rail arming are both
       exercised. editor-gutter-quiet places a rail with no callback and no
       LexicalGutterButton — it reveals and its plain @onclick button works with zero
       JS→.NET calls. *@
    <LexicalEditor @ref="_gutterNotify"
                   Id="editor-gutter-notify"
                   CssClass="harness-gutter-notify"
                   Theme="LexicalTheme.Default">
        <LexicalBlockGutter Position="LexicalGutterPosition.LeftInside" CssClass="harness-gutter-left">
            <LexicalAddBlockButton />
            <LexicalDragHandle />
        </LexicalBlockGutter>
        @* Deliberately OUTSIDE the card: that is the layout the hover grace window has to
           survive, since travelling to it crosses page pixels the editor root does not own. *@
        <LexicalBlockGutter @ref="_gutterNotifyExt"
                            Position="LexicalGutterPosition.RightOutside"
                            CssClass="harness-gutter-right"
                            OnBlockHovered="OnBlockHovered">
            <button id="btn-gutter-action" type="button" @onclick="GutterAction">★</button>
            @* The typed item: it is handed the block itself, no @ref bookkeeping. *@
            <LexicalGutterButton OnClick="GutterTypedAction" CssClass="harness-gutter-typed">☆</LexicalGutterButton>
        </LexicalBlockGutter>
    </LexicalEditor>
    <p>Gutter hovered: <span id="gutter-hovered">@_gutterHovered</span></p>
    <p>Gutter hover count: <span id="gutter-hover-count">@_gutterHoverCount</span></p>
    <p>Gutter action: <span id="gutter-action">@_gutterAction</span></p>
    <p>Gutter typed action: <span id="gutter-typed-action">@_gutterTypedAction</span></p>

    <LexicalEditor Id="editor-gutter-quiet"
                   CssClass="harness-gutter-quiet"
                   Theme="LexicalTheme.Default">
        <LexicalBlockGutter Position="LexicalGutterPosition.LeftInside">
            <button id="btn-gutter-quiet-action" type="button" @onclick="GutterQuietAction">☆</button>
        </LexicalBlockGutter>
    </LexicalEditor>
    <p>Gutter quiet action: <span id="gutter-quiet-action">@_gutterQuietAction</span></p>
</section>

<section>
    <h2>Initial content — one editor per format, loaded inside create()</h2>
    @* No @ref and no OnReady: the document is applied while the editor is created, so
       it is present on the first paint (data-lexical-empty is never set) and it is the
       history baseline — undo must not empty these. *@
    <LexicalEditor Id="editor-initial-html"
                   CssClass="harness-initial-html"
                   InitialContent="@LexicalContent.FromHtml(InitialHtml)"
                   Theme="LexicalTheme.Default" />

    <LexicalEditor Id="editor-initial-text"
                   CssClass="harness-initial-text"
                   InitialContent="@LexicalContent.FromText(InitialText)" />

    <LexicalEditor Id="editor-initial-md"
                   CssClass="harness-initial-md"
                   InitialContent="@LexicalContent.FromMarkdown(InitialMarkdown)" />

    <LexicalEditor @ref="_initialJson"
                   Id="editor-initial-json"
                   CssClass="harness-initial-json"
                   InitialContent="@LexicalContent.FromEditorStateJson(InitialStateJson)" />

    <div>
        <button id="btn-initial-undo" @onclick="UndoInitialJson">Undo (json editor)</button>
        <button id="btn-initial-ready" @onclick="ReadInitialReady">Read IsReady</button>
        <button id="btn-content-roundtrip" @onclick="RoundTripContent">Round-trip content</button>
    </div>
    <p>Initial IsReady: <span id="initial-ready">@_initialReady</span></p>
    <p>Round-trip result: <span id="content-roundtrip">@_contentRoundTrip</span></p>
</section>

<section>
    <h2>Content payload — SignalOnly (dirty signal without the document)</h2>
    @* The same opt-in channel as .harness-notify, but carrying no body: the callback
       fires with an empty LexicalContent and LastContent stays null. *@
    <LexicalEditor @ref="_signal"
                   Id="editor-signal"
                   CssClass="harness-signal"
                   ContentPayload="LexicalContentPayload.SignalOnly"
                   OnContentChanged="OnSignalContent" />
    <div>
        <button id="btn-signal-last" @onclick="ReadSignalLast">Read LastContentText</button>
        <button id="btn-notify-last" @onclick="ReadNotifyLast">Read notify LastContentText</button>
    </div>
    <p>Signal count: <span id="signal-count">@_signalCount</span></p>
    <p>Signal arg length: <span id="signal-arg-length">@_signalArgLength</span></p>
    <p>Signal last: <span id="signal-last">@_signalLast</span></p>
    <p>Notify last: <span id="notify-last">@_notifyLast</span></p>
</section>

<section>
    <h2>Content payload — a format-carrying push (HTML, one crossing)</h2>
    @* The subscriber declares HTML, so the document is serialized JS-side inside the
       debounce and arrives ready to use — no plain-text push followed by a getHtml
       round trip. The format rides along on the value. *@
    <LexicalEditor Id="editor-payload-html"
                   CssClass="harness-payload-html"
                   ContentPayload="LexicalContentPayload.Html"
                   OnContentChanged="OnHtmlPayload" />
    <p>HTML payload format: <span id="payload-html-format">@_htmlPayloadFormat</span></p>
    <p>HTML payload: <span id="payload-html-text">@_htmlPayloadText</span></p>
</section>

<section>
    <h2>Toolbar — StartContent/EndContent added to the default set</h2>
    @* The default controls still render; the two fragments bracket them. *@
    <LexicalEditor Id="editor-toolbar-extra" CssClass="harness-toolbar-extra">
        <LexicalToolbar>
            <StartContent>
                <button id="btn-toolbar-start" type="button">Start</button>
            </StartContent>
            <EndContent>
                <button id="btn-toolbar-end" type="button">End</button>
            </EndContent>
        </LexicalToolbar>
    </LexicalEditor>
</section>

<section>
    <h2>Mentions — a provider slower than its QueryTimeout</h2>
    @* Proves the loading affordance and the soft timeout: the menu shows
       data-lexical-mention-loading while the query is in flight, then closes when the
       provider blows the deadline instead of stranding the session. *@
    <LexicalEditor Id="editor-mention-slow"
                   CssClass="harness-mention-slow"
                   Placeholder="Type a mention…"
                   Theme="LexicalTheme.Default">
        <LexicalMention Initiator="@AtInitiator"
                        Color="#1877e8"
                        Provider="ResolveSlowly"
                        QueryTimeout="@TimeSpan.FromMilliseconds(600)" />
    </LexicalEditor>
</section>

<section>
    <h2>History disabled</h2>
    <LexicalEditor Id="editor-nohistory" EnableHistory="false" />
</section>

<section>
    <h2>Read-only (created read-only)</h2>
    <LexicalEditor Id="editor-readonly" ReadOnly="true" />
</section>

<section>
    <h2>Toggle read-only (setEditable)</h2>
    <LexicalEditor Id="editor-toggle" ReadOnly="_toggleReadOnly" />
    <button id="btn-toggle" @onclick="() => _toggleReadOnly = !_toggleReadOnly">
        Toggle read-only (now: <span id="toggle-state">@(_toggleReadOnly ? "readonly" : "editable")</span>)
    </button>
</section>

<section>
    <h2>Disposable (dispose on removal)</h2>
    @if (_showDisposable)
    {
        <LexicalEditor Id="editor-disposable" />
    }
    <button id="btn-remove" @onclick="() => _showDisposable = false">Remove</button>
    <button id="btn-readd" @onclick="() => _showDisposable = true">Re-add</button>
</section>

@code {
    // Stable URL asserted by the link integration tests.
    private const string LinkUrl = "https://example.com/";

    // The mention initiator, bound rather than inlined so the "@" isn't parsed as Razor.
    private const string AtInitiator = "@";

    private LexicalEditor? _main;
    private LexicalEditor? _lists;
    private LexicalEditor? _links;
    private LexicalEditor? _format;
    private LexicalEditor? _notify;
    private LexicalEditor? _tables;
    private LexicalEditor? _mentionPeople;
    private LexicalEditor? _badgeNotify;
    private LexicalEditor? _initialJson;
    private LexicalEditor? _signal;
    private BadgeExtension? _badgeNotifyExt;
    private string _getResult = "";
    private string _changeLog = "";
    private int _changeCount;
    private bool _toggleReadOnly;
    private bool _showDisposable = true;
    private string _htmlResult = "";
    private string _markdownResult = "";
    private string _jsonResult = "";
    private string _capturedJson = "";
    private string _listMarkdownResult = "";
    private string _linkMarkdownResult = "";
    private string _fmtHtmlResult = "";
    private string _tablesHtmlResult = "";
    private string _notifyChange = "";
    private int _notifyChangeCount;
    private string _notifySelBold = "";
    private string _notifySelBlock = "";
    private int _notifySelCount;
    private string _mentionSelected = "";
    private string _mentionList = "";
    private int _mentionRefreshCount;
    private int _mentionChangeCount;
    private string _badgeClicked = "";
    private int _badgeClickCount;
    private int _badgeCount;
    private string _badgeHtmlResult = "";
    private string _initialReady = "";
    private string _contentRoundTrip = "";
    private string _htmlPayloadFormat = "";
    private string _htmlPayloadText = "";
    private int _signalCount;
    private int _signalArgLength = -1;
    private string _signalLast = "";
    private string _notifyLast = "";

    private LexicalEditor? _hrEditor;
    private LexicalHorizontalRule? _hrExt;
    private string _hrHtml = "";

    private LexicalEditor? _tabIndent;
    private LexicalEditor? _tabCapped;
    private LexicalEditor? _tabPlain;
    private string _tabIndentLevel = "";

    private LexicalEditor? _tocNotify;
    private LexicalToc? _tocNotifyExt;
    private IReadOnlyList<LexicalTocEntry> _tocEntries = [];
    private int _tocCount;
    private int _tocPushCount;
    private string _tocFlat = "";
    private string _tocGetResult = "";
    private string _tocScrollResult = "";

    private LexicalEditor? _marksNotify;
    private LexicalEditor? _marksQuiet;
    private LexicalMarks? _marksNotifyExt;
    private LexicalMarks? _marksQuietExt;
    private string _markClicked = "";
    private string _markActive = "";
    private string _markIds = "";
    private string _markIdsAtSelection = "";
    private string _markWrapResult = "";
    private int _markRemoveCount;
    private int _marksChangeCount;

    private LexicalEditor? _statsNotify;
    private LexicalStats? _statsNotifyExt;
    private string _statsPush = "";
    private string _statsGetResult = "";

    private LexicalEditor? _gutterNotify;
    private LexicalBlockGutter? _gutterNotifyExt;
    private string _gutterHovered = "";
    private int _gutterHoverCount;
    private string _gutterAction = "";
    private string _gutterTypedAction = "";
    private string _gutterQuietAction = "";

    // --- TOC ------------------------------------------------------------

    // The push carries the whole tree, so nothing here needs a follow-up call.
    private void OnTocChanged(IReadOnlyList<LexicalTocEntry> entries)
    {
        _tocEntries = entries;
        _tocCount = entries.Count;
        _tocPushCount++;
        _tocFlat = string.Join(",", Flatten(entries).Select(e => $"{e.Level}:{e.AnchorId}"));
    }

    /// <summary>Depth-first walk, so a test can assert nesting from one flat string.</summary>
    private static IEnumerable<LexicalTocEntry> Flatten(IReadOnlyList<LexicalTocEntry> entries)
    {
        foreach (var entry in entries)
        {
            yield return entry;
            foreach (var child in Flatten(entry.Children))
            {
                yield return child;
            }
        }
    }

    private async Task GetToc()
    {
        if (_tocNotifyExt is not null)
        {
            var entries = await _tocNotifyExt.GetTocAsync();
            _tocGetResult = string.Join(",", Flatten(entries).Select(e => e.AnchorId));
        }
    }

    private async Task ScrollToFirstAnchor()
    {
        if (_tocNotifyExt is not null)
        {
            var first = _tocEntries.FirstOrDefault();
            _tocScrollResult = first is null
                ? "(none)"
                : (await _tocNotifyExt.ScrollToAnchorAsync(first.AnchorId)).ToString();
        }
    }

    // --- Marks ----------------------------------------------------------

    private void OnMarksContent(LexicalContent content) => _marksChangeCount++;

    private void OnMarkClicked(IReadOnlyList<string> ids) => _markClicked = string.Join(",", ids);

    private void OnActiveMarksChanged(IReadOnlyList<string> ids) =>
        _markActive = string.Join(",", ids);

    // The id is minted here, by the app — that is the whole contract.
    private async Task WrapMark(string markId)
    {
        if (_marksNotifyExt is not null)
        {
            _markWrapResult = (await _marksNotifyExt.WrapSelectionInMarkAsync(markId)).ToString();
        }
    }

    private async Task WrapQuietMark()
    {
        if (_marksQuietExt is not null)
        {
            await _marksQuietExt.WrapSelectionInMarkAsync("quiet-mark");
        }
    }

    private async Task ListMarkIds()
    {
        if (_marksNotifyExt is not null)
        {
            _markIds = string.Join(",", await _marksNotifyExt.GetMarkIdsAsync());
        }
    }

    private async Task ListMarkIdsAtSelection()
    {
        if (_marksNotifyExt is not null)
        {
            _markIdsAtSelection =
                string.Join(",", await _marksNotifyExt.GetMarkIdsAtSelectionAsync());
        }
    }

    private async Task RemoveMark(string markId, bool silent)
    {
        if (_marksNotifyExt is not null)
        {
            _markRemoveCount = await _marksNotifyExt.RemoveMarkAsync(markId, silent);
        }
    }

    private async Task SetActiveMark(string markId)
    {
        if (_marksNotifyExt is not null)
        {
            await _marksNotifyExt.SetActiveMarkAsync(markId);
        }
    }

    // --- Stats ----------------------------------------------------------

    private void OnStatsChanged(LexicalDocumentStats stats) =>
        _statsPush = $"{stats.Words}|{stats.Characters}|{stats.Paragraphs}|{stats.ReadingMinutes}";

    private Task ReadTabIndent() => ReadIndentLevel(_tabIndent);

    private Task ReadCappedIndent() => ReadIndentLevel(_tabCapped);

    private Task ReadPlainIndent() => ReadIndentLevel(_tabPlain);

    /// <summary>Reports the first block's indent level, straight out of the editor state.</summary>
    private async Task ReadIndentLevel(LexicalEditor? editor)
    {
        if (editor is null)
        {
            return;
        }

        using var document = System.Text.Json.JsonDocument.Parse(
            await editor.GetEditorStateJsonAsync());
        var children = document.RootElement.GetProperty("root").GetProperty("children");
        var level = children.GetArrayLength() == 0
            ? -1
            : children[0].TryGetProperty("indent", out var indent) ? indent.GetInt32() : 0;
        _tabIndentLevel = level < 0 ? "none" : level.ToString();
    }

    private async Task InsertRuleFromCSharp()
    {
        if (_hrExt is not null)
        {
            await _hrExt.InsertAsync();
        }
    }

    private async Task GetHrHtml()
    {
        if (_hrEditor is not null)
        {
            _hrHtml = await _hrEditor.GetHtmlAsync();
        }
    }

    private async Task SetHrHtml()
    {
        if (_hrEditor is not null)
        {
            await _hrEditor.SetHtmlAsync("<p>above</p><hr><p>below</p>");
        }
    }

    private async Task GetStats()
    {
        if (_statsNotifyExt is not null)
        {
            var stats = await _statsNotifyExt.GetStatsAsync();
            _statsGetResult = $"{stats.Words}|{stats.CharactersNoSpaces}";
        }
    }

    // --- Block gutter ---------------------------------------------------

    private void OnBlockHovered(LexicalBlockRef? block)
    {
        _gutterHovered = block is null ? "(none)" : $"{block.Index}|{block.BlockType}";
        _gutterHoverCount++;
    }

    // An ordinary Blazor @onclick inside the gutter — invariant 4's escape hatch. It
    // reads HoveredBlock for the block it acts on.
    private void GutterAction() =>
        _gutterAction = _gutterNotifyExt?.HoveredBlock is { } block
            ? $"{block.Index}|{block.TextPreview}"
            : "(no block)";

    // The typed item is handed the block directly — no @ref, no HoveredBlock read.
    private void GutterTypedAction(LexicalBlockRef? block) =>
        _gutterTypedAction = block is null ? "(no block)" : $"{block.Index}|{block.BlockType}";

    private void GutterQuietAction() => _gutterQuietAction = "clicked";

    // Initial content, one constant per format. Each carries a distinct marker string
    // so a test can tell which format actually loaded.
    private const string InitialHtml = "<p>Initial <strong>html</strong> content</p>";
    private const string InitialText = "Initial text content";
    private const string InitialMarkdown = "## Initial markdown heading";
    private const string InitialStateJson =
        """
        {"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"",
        "text":"Initial state json content","type":"text","version":1}],"direction":"ltr",
        "format":"","indent":0,"type":"paragraph","version":1}],"direction":"ltr","format":"",
        "indent":0,"type":"root","version":1}}
        """;

    // A provider that never answers in time — the QueryTimeout must close the picker.
    private static async Task<IEnumerable<MentionItem>> ResolveSlowly(string query)
    {
        await Task.Delay(5000);
        return People;
    }

    private void OnSignalContent(LexicalContent content)
    {
        _signalCount++;
        _signalArgLength = content.Text.Length;
    }

    private void OnHtmlPayload(LexicalContent content)
    {
        _htmlPayloadFormat = content.Format.ToString();
        _htmlPayloadText = content.Text;
    }

    private void ReadSignalLast() =>
        _signalLast = _signal?.LastContent is { } c ? c.Text : "(null)";

    private void ReadNotifyLast() =>
        _notifyLast = _notify?.LastContent is { } c ? $"{c.Format}|{c.Text}" : "(null)";

    private void ReadInitialReady() => _initialReady = _initialJson?.IsReady.ToString() ?? "(null)";

    // The generic, format-as-a-value pair: read the document in a format chosen at
    // runtime, then write the same value straight back.
    private async Task RoundTripContent()
    {
        if (_initialJson is null)
        {
            return;
        }
        var content = await _initialJson.GetContentAsync(LexicalContentFormat.Markdown);
        await _initialJson.SetContentAsync(content);
        _contentRoundTrip = $"{content.Format}|{content.Text}";
    }

    private async Task UndoInitialJson()
    {
        if (_initialJson is not null)
        {
            await _initialJson.UndoAsync();
        }
    }

    // A fixed directory the fake provider searches — stands in for a GAL/host lookup.
    private static readonly MentionItem[] People =
    [
        new("1", "Luke Skywalker", "/u/luke", "Jedi"),
        new("2", "Leia Organa", "/u/leia", "General"),
        new("3", "Han Solo", "/u/han", "Smuggler"),
    ];

    private Task<IEnumerable<MentionItem>> ResolvePeople(string query)
    {
        var matches = People.Where(p =>
            p.Text.Contains(query, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<MentionItem>>(matches);
    }

    private void OnMentionContent(LexicalContent content) => _mentionChangeCount++;

    private void OnMentionSelected(LexicalMentionSelected selected) =>
        _mentionSelected = $"{selected.Text}|{selected.Id}";

    private async Task GetMentionList()
    {
        if (_mentionPeople is not null)
        {
            var mentions = await _mentionPeople.GetMentionsAsync();
            _mentionList = string.Join(
                ",", mentions.Select(m => $"{m.Text}|{m.Value}|{m.Initiator}"));
        }
    }

    // Discovers the config id + value of the first mention, then renames every
    // occurrence of that value. The rename is silent — it must not bump the
    // content-change count above.
    private async Task RefreshMentionName()
    {
        if (_mentionPeople is null)
        {
            return;
        }
        var mentions = await _mentionPeople.GetMentionsAsync();
        var first = mentions.FirstOrDefault();
        if (first is not null)
        {
            _mentionRefreshCount = await _mentionPeople.RefreshMentionsByValueAsync(
                first.ConfigId, first.Value, "Luke S. (renamed)", "/u/luke-renamed");
        }
    }

    // The extension's opt-in JS→.NET channel (its own [JSInvokable] route, not the
    // editor's content/selection channels).
    private void OnBadgeClicked(string text)
    {
        _badgeClicked = text;
        _badgeClickCount++;
    }

    // The .NET→JS direction: C# asks the extension's JS half to insert / count.
    private async Task InsertBadgeFromCs()
    {
        if (_badgeNotifyExt is not null)
        {
            await _badgeNotifyExt.InsertBadgeAsync("From C#");
        }
    }

    private async Task CountBadges()
    {
        if (_badgeNotifyExt is not null)
        {
            _badgeCount = await _badgeNotifyExt.CountBadgesAsync();
        }
    }

    private async Task GetBadgeHtml()
    {
        if (_badgeNotify is not null)
        {
            _badgeHtmlResult = await _badgeNotify.GetHtmlAsync();
        }
    }

    private void OnMainChanged(LexicalContent content)
    {
        _changeLog = content.Text;
        _changeCount++;
    }

    private void OnNotifyContent(LexicalContent content)
    {
        _notifyChange = content.Text;
        _notifyChangeCount++;
    }

    private void OnNotifySelection(LexicalSelectionState state)
    {
        _notifySelBold = state.IsBold ? "true" : "false";
        _notifySelBlock = state.BlockType.ToString();
        _notifySelCount++;
    }

    private async Task FormatFmt(LexicalTextFormat format)
    {
        if (_format is not null)
        {
            await _format.FormatTextAsync(format);
        }
    }

    private async Task BlockFmt(LexicalBlockType blockType)
    {
        if (_format is not null)
        {
            await _format.SetBlockTypeAsync(blockType);
        }
    }

    private async Task UndoFmt()
    {
        if (_format is not null)
        {
            await _format.UndoAsync();
        }
    }

    private async Task RedoFmt()
    {
        if (_format is not null)
        {
            await _format.RedoAsync();
        }
    }

    private async Task GetFmtHtml()
    {
        if (_format is not null)
        {
            _fmtHtmlResult = await _format.GetHtmlAsync();
        }
    }

    private async Task InsertTableFmt()
    {
        if (_tables is not null)
        {
            await _tables.InsertTableAsync(2, 3);
        }
    }

    private async Task GetTablesHtml()
    {
        if (_tables is not null)
        {
            _tablesHtmlResult = await _tables.GetHtmlAsync();
        }
    }

    private async Task GetMain()
    {
        if (_main is not null)
        {
            _getResult = await _main.GetTextAsync();
        }
    }

    private async Task SetMain()
    {
        if (_main is not null)
        {
            await _main.SetTextAsync("Set via C#");
        }
    }

    private async Task GetHtml()
    {
        if (_main is not null)
        {
            _htmlResult = await _main.GetHtmlAsync();
        }
    }

    private async Task SetHtml()
    {
        if (_main is not null)
        {
            await _main.SetHtmlAsync("<h1>HTML heading</h1><p>HTML <strong>bold</strong> body</p>");
        }
    }

    private async Task GetMarkdown()
    {
        if (_main is not null)
        {
            _markdownResult = await _main.GetMarkdownAsync();
        }
    }

    private async Task SetMarkdown()
    {
        if (_main is not null)
        {
            await _main.SetMarkdownAsync("# Markdown heading\n\nMarkdown **bold** body");
        }
    }

    // Captures the current editor state as JSON. The Set button restores it,
    // so the round-trip covers both getEditorStateJson and setEditorStateJson.
    private async Task GetJson()
    {
        if (_main is not null)
        {
            _capturedJson = await _main.GetEditorStateJsonAsync();
            _jsonResult = _capturedJson;
        }
    }

    private async Task SetJson()
    {
        if (_main is not null && _capturedJson.Length > 0)
        {
            await _main.SetEditorStateJsonAsync(_capturedJson);
        }
    }

    // Lists: insertUnorderedList / insertOrderedList / removeList touchpoints.
    private async Task InsertUnordered()
    {
        if (_lists is not null)
        {
            await _lists.InsertUnorderedListAsync();
        }
    }

    private async Task InsertOrdered()
    {
        if (_lists is not null)
        {
            await _lists.InsertOrderedListAsync();
        }
    }

    private async Task RemoveListFmt()
    {
        if (_lists is not null)
        {
            await _lists.RemoveListAsync();
        }
    }

    // Round-trips list markdown to exercise the @lexical/list nodes' Markdown
    // transformers (registered via createEditor's nodes[]).
    private async Task SetListMarkdown()
    {
        if (_lists is not null)
        {
            await _lists.SetMarkdownAsync("- one\n- two\n- three");
        }
    }

    private async Task GetListMarkdown()
    {
        if (_lists is not null)
        {
            _listMarkdownResult = await _lists.GetMarkdownAsync();
        }
    }

    // Links: toggleLink set / remove touchpoints.
    private async Task SetLink()
    {
        if (_links is not null)
        {
            await _links.SetLinkAsync(LinkUrl);
        }
    }

    private async Task RemoveLink()
    {
        if (_links is not null)
        {
            await _links.RemoveLinkAsync();
        }
    }

    // Round-trips link markdown to exercise the @lexical/link node's Markdown
    // transformer.
    private async Task SetLinkMarkdown()
    {
        if (_links is not null)
        {
            await _links.SetMarkdownAsync($"see [Example]({LinkUrl}) now");
        }
    }

    private async Task GetLinkMarkdown()
    {
        if (_links is not null)
        {
            _linkMarkdownResult = await _links.GetMarkdownAsync();
        }
    }
}
